name: Extract Android mPaaS SDK

on: 
  workflow_dispatch:

jobs:
  build:
    # 리눅스 환경 사용 (속도가 매우 빠르고 페널티가 없어 사실상 무제한 무료)
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up JDK 17
        uses: actions/setup-java@v3
        with:
          java-version: '17'
          distribution: 'temurin'

      - name: Create Gradle Build Script
        run: |
          # Android Studio 없이 의존성만 다운로드하는 경량 Gradle 스크립트 생성
          cat <<EOF > build.gradle
          plugins {
              id 'java'
          }

          repositories {
              google()
              mavenCentral()
              maven {
                  url "http://mvn.cloud.alipay.com/nexus/content/repositories/releases/"
                  allowInsecureProtocol = true // HTTP 우회
                  credentials {
                      username "mvn_read_ws"
                      password "mrk8929"
                  }
              }
          }

          // 다운로드를 위한 전용 설정
          configurations { downloadTarget }

          dependencies {
              downloadTarget platform("com.mpaas.android:mpaas-baseline:10.2.3")
              downloadTarget "com.mpaas.android:datacenter"
          }

          task fetchDependencies {
              doLast {
                  configurations.downloadTarget.resolve()
                  println "Dependencies successfully downloaded to Gradle cache."
              }
          }
          EOF

      - name: Download SDK via Gradle
        run: |
          # 의존성 다운로드 실행
          gradle fetchDependencies

      - name: Collect and Zip Artifacts
        run: |
          # 다운로드된 캐시 폴더에서 AAR 및 JAR 파일만 긁어모아 압축
          mkdir mPaaS_Android_SDK
          find ~/.gradle/caches/modules-2/files-2.1/ -name "*.aar" -exec cp {} mPaaS_Android_SDK/ \;
          find ~/.gradle/caches/modules-2/files-2.1/ -name "*.jar" -exec cp {} mPaaS_Android_SDK/ \;
          
          zip -r mPaaS_Android_SDK.zip mPaaS_Android_SDK/

      - name: Upload Artifact for Download
        uses: actions/upload-artifact@v4
        with:
          name: mPaaS_Official_AARs
          path: mPaaS_Android_SDK.zip
          retention-days: 1
